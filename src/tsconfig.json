{
    "compilerOptions": {
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "noEmit": true,
        "target": "ES6",
        "module": "ESNext",
        "jsx": "react-jsx",
        "baseUrl": "./",
        "paths": {
            "*": [
                "node_modules/*"
            ]
        },
    }
}